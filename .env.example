# Optional opt-out from the default Docker Hardened runtime images.
# Uncomment these to force the upstream non-DHI images instead.

# PYTHON_BUILD_IMAGE=python:3.13-slim
# PYTHON_RUNTIME_IMAGE=python:3.13-slim

# Published host port for the simulator.
# FOUNDRY_PORT=8020

# Config file loaded at startup (path inside the container).
# AIFOUNDRY_CONFIG_PATH=/app/examples/foundry.json

# Simulated per-request model latency override in milliseconds.
# Set to make semantic-cache hits visibly faster than misses.
# FOUNDRY_LATENCY_MS=400

# Runtime UID/GID for the non-root container user.
APP_UID=65532
APP_GID=65532
